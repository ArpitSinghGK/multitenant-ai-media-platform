# ---- Application ----
APP_ENV=local
APP_NAME="Multi-Tenant AI Media Platform"
LOG_LEVEL=INFO

# ---- Postgres (Control Plane state: tenants, wallets, jobs, entitlements) ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aiplatform

# ---- Redis (Celery broker + result backend + rate limiting) ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Supabase (self-hosted): JWT verification + RBAC ----
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me-with-your-jwt-secret

# ---- RunPod Serverless GPU workers ----
RUNPOD_API_KEY=replace-me
RUNPOD_ENDPOINT_AUDIOCRAFT=https://api.runpod.ai/v2/xxxxxxxx/run
RUNPOD_ENDPOINT_AMPHION=https://api.runpod.ai/v2/xxxxxxxx/run
RUNPOD_ENDPOINT_OPENVOICE=https://api.runpod.ai/v2/xxxxxxxx/run
RUNPOD_ENDPOINT_RVC=https://api.runpod.ai/v2/xxxxxxxx/run
RUNPOD_ENDPOINT_COMFYUI=https://api.runpod.ai/v2/xxxxxxxx/run

# ---- Artifact storage (S3-compatible; e.g. Supabase Storage / MinIO) ----
ARTIFACT_BUCKET_URL=s3://ai-artifacts
ARTIFACT_SIGNED_URL_TTL=3600
